# ============================================
# SĒAL Fluence TEE Runtime — Environment Config
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ------------------------------------------
# REQUIRED — Claude LLM (Dev B core)
# ------------------------------------------
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ------------------------------------------
# REQUIRED for Day 2+ — EVM Contract (Dev A integration)
# ------------------------------------------
# Base Sepolia testnet RPC (free from Alchemy/Infura/QuickNode)
RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Dev A deploys the SEAL contract, paste address here once ready
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# Wallet private key for signing on-chain txs (use a TESTNET wallet only!)
SIGNER_PRIVATE_KEY=YOUR_SIGNER_PRIVATE_KEY

# ------------------------------------------
# OPTIONAL — Gemini LLM (fallback if Claude has no credits)
# ------------------------------------------
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ------------------------------------------
# OPTIONAL — Fluence Network
# ------------------------------------------
# Fluence relay peer ID (default: Kras testnet)
FLUENCE_RELAY=/dns4/0-kras.fluence.dev/tcp/9990/ws/p2p/12D3KooWSD5PToNiLQwKDXsu8JSyJRKjKT7MognTHiW5bob6NLCF

# ------------------------------------------
# OPTIONAL — Server config (if running as API)
# ------------------------------------------
PORT=3001
NODE_ENV=development

# ------------------------------------------
# Storacha
# 1. Install CLI: npm i -g @web3-storage/w3cli
# 2. Run: w3 login your@email.com  (one-time)
# 3. Run: w3 space create seal-protocol
# 4. Run: w3 key create  →  paste output as STORACHA_PRINCIPAL
# 5. Run: w3 delegation create <did from step 4> | base64  →  paste as STORACHA_PROOF
STORACHA_PRINCIPAL=
STORACHA_PROOF=

LIT_NETWORK=nagaTest